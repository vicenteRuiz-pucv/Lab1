modules = ["bash"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["gdb"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run Tests"

[[workflows.workflow]]
name = "Run Tests"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash test.sh"

[workflows.workflow.metadata]
outputType = "console"
